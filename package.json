{
  "name": "exploding-kittens",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "server": "npm run build:server && node dist/server/server/server.js",
